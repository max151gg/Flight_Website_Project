@using SkyPath_Models.Models
@using SkyPath_Models.ViewModel
@model BrowseViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/MasterPage.cshtml";
}
@{
    var cityDict = (Dictionary<string, string>)ViewBag.CityDict;
    string NameOrUnknown(string id) =>
        (!string.IsNullOrEmpty(id) && cityDict != null && cityDict.ContainsKey(id))
            ? cityDict[id] : "Unknown";
}
<link rel="stylesheet" href="~/CSS/login_homeCSS.css" />

<div class="content">
    <div class="hero">
        <h1>The best site to set up<br>your vacation</h1>
        <p>Statement for your product's tagline. This text should communicate your unique selling proposition to the reader.</p>
        <a class="btn-cta" href="http://localhost:5076/Guest/Browse">Find Your Flight Now</a>
    </div>

    <div class="main-container">
        @{
            var discountedFlights = (Model?.flights ?? new List<Flight>())
            .Where(f => f != null).OrderBy(f => f.Price).Take(5).ToList();
        }

        <div class="flights-section">
            <p class="section-title">Cheapest Flights Available Right Now</p>
            <div class="flight-cards">
                @foreach (var flight in discountedFlights)
                {
                    <a href="/Guest/FlightDetail?flight_id=@flight.Flight_Id" class="flight-card-link">
                        <div class="flight-card">
                            <div class="flight-card-title">
                                @NameOrUnknown(flight.Departure_Id) → @NameOrUnknown(flight.Arrival_Id) - @flight.Price$
                            </div>
                        </div>
                    </a>
                }
            </div>
        </div>

        <div class="content-layout">
            <div class="signup-section" id="login-section">
                <h2>Log In</h2>

                @* novalidate disables browser bubbles — our server-side + field errors appear instead *@
                <form asp-controller="Guest" asp-action="Login" method="post" novalidate>

                    @* Show "Invalid email or password" from the controller *@
                    @if (ViewData.ModelState.ContainsKey("") &&
                                        ViewData.ModelState[""].Errors.Count > 0)
                    {
                        <div class="general-error">
                            @ViewData.ModelState[""].Errors[0].ErrorMessage
                        </div>
                    }

                    <div class="form-group">
                        <input asp-for="LoginViewModel.Email"
                               type="text"
                               placeholder="Email" />
                        <span asp-validation-for="LoginViewModel.Email" class="field-error"></span>
                    </div>

                    <div class="form-group">
                        <input asp-for="LoginViewModel.Password"
                               type="password"
                               placeholder="Password" />
                        <span asp-validation-for="LoginViewModel.Password" class="field-error"></span>
                    </div>

                    <div class="checkbox-group">
                        <label>
                            Don't have an account?
                            <a href="http://localhost:5076/Guest/HomePage#signup-section">Sign Up</a>
                        </label>
                    </div>

                    <button type="submit" class="btn-submit">Log In</button>
                </form>
            </div>
        </div>
    </div>
    @if (!ViewData.ModelState.IsValid)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var section = document.getElementById('login-section');
                if (section) section.scrollIntoView({ behavior: 'smooth', block: 'start' });
            });
        </script>
    }
</div>
