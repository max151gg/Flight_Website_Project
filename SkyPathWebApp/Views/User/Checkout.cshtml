@using SkyPath_Models.Models
@using SkyPath_Models.ViewModel
@model CheckoutViewModel

@{
    ViewData["Title"] = "Checkout";
    Layout = "~/Views/Shared/MasterPage_User.cshtml";

    var cityDict = (Dictionary<string, string>)(ViewBag.CityDict ?? new Dictionary<string, string>());

    string CityName(string id) =>
        (!string.IsNullOrEmpty(id) && cityDict.ContainsKey(id)) ? cityDict[id] : "Unknown";
}

<link rel="stylesheet" href="~/css/CheckoutCSS.css" />

<div class="checkout-container">
    <h2 class="checkout-title">Booking Summary</h2>

    <div class="checkout-layout">
        <!-- LEFT: Flight details -->
        <div class="checkout-left">

            <!-- Outbound Flight Card -->
            <div class="section-label">Outbound Flight</div>
            <div class="flight-detail-card">
                <div class="fdc-route">
                    @CityName(Model.OutboundFlight.Departure_Id)
                    <span class="fdc-arrow">✈</span>
                    @CityName(Model.OutboundFlight.Arrival_Id)
                </div>
                <div class="fdc-grid">
                    <div class="fdc-box">
                        <div class="fdc-label">Flight Number</div>
                        <div class="fdc-value">@Model.OutboundFlight.Flight_Number</div>
                    </div>
                    <div class="fdc-box">
                        <div class="fdc-label">Airline</div>
                        <div class="fdc-value">@Model.OutboundFlight.Airline</div>
                    </div>
                    <div class="fdc-box">
                        <div class="fdc-label">Departure</div>
                        <div class="fdc-value">@Model.OutboundFlight.Departure_Date &bull; @Model.OutboundFlight.Departure_Time</div>
                    </div>
                    <div class="fdc-box">
                        <div class="fdc-label">Arrival</div>
                        <div class="fdc-value">@Model.OutboundFlight.Arrival_Date &bull; @Model.OutboundFlight.Arrival_Time</div>
                    </div>
                    <div class="fdc-box">
                        <div class="fdc-label">Duration</div>
                        <div class="fdc-value">@(Model.OutboundFlight.DurationDisplay ?? "—")</div>
                    </div>
                    <div class="fdc-box">
                        <div class="fdc-label">Price</div>
                        <div class="fdc-value fdc-price">@Model.OutboundFlight.Price$</div>
                    </div>
                    <div class="fdc-box">
                        <div class="fdc-label">Seats Left</div>
                        <div class="fdc-value">@Model.OutboundFlight.Seats_Available</div>
                    </div>
                </div>
            </div>

            <!-- Return Flight Section -->
            <div class="section-label" style="margin-top:24px;">Return Flight (optional)</div>

            @if (Model.AvailableReturnFlights != null && Model.AvailableReturnFlights.Count > 0)
            {
                <select class="return-select" id="returnFlightSelect" onchange="onReturnFlightChanged()">
                    <option value="">— One-way, no return —</option>
                    @foreach (var rf in Model.AvailableReturnFlights)
                    {
                        <option value="@rf.Flight_Id">
                            @CityName(rf.Departure_Id) → @CityName(rf.Arrival_Id)
                            | @rf.Departure_Date @rf.Departure_Time
                            | @rf.Price$
                        </option>
                    }
                </select>

                <!-- Return flight detail card (hidden until selected) -->
                <div class="flight-detail-card" id="returnFlightCard" style="display:none; margin-top:16px;">
                    <div class="fdc-route" id="retRoute">—</div>
                    <div class="fdc-grid">
                        <div class="fdc-box">
                            <div class="fdc-label">Flight Number</div>
                            <div class="fdc-value" id="retFlightNumber">—</div>
                        </div>
                        <div class="fdc-box">
                            <div class="fdc-label">Airline</div>
                            <div class="fdc-value" id="retAirline">—</div>
                        </div>
                        <div class="fdc-box">
                            <div class="fdc-label">Departure</div>
                            <div class="fdc-value"><span id="retDepDate">—</span> &bull; <span id="retDepTime">—</span></div>
                        </div>
                        <div class="fdc-box">
                            <div class="fdc-label">Arrival</div>
                            <div class="fdc-value"><span id="retArrDate">—</span> &bull; <span id="retArrTime">—</span></div>
                        </div>
                        <div class="fdc-box">
                            <div class="fdc-label">Duration</div>
                            <div class="fdc-value" id="retDuration">—</div>
                        </div>
                        <div class="fdc-box">
                            <div class="fdc-label">Price</div>
                            <div class="fdc-value fdc-price" id="retPrice">—</div>
                        </div>
                        <div class="fdc-box">
                            <div class="fdc-label">Seats Left</div>
                            <div class="fdc-value" id="retSeats">—</div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="no-return-note">No return flights available for this route.</div>
            }
        </div>

        <!-- RIGHT: Price summary -->
        <div class="checkout-right">
            <div class="price-summary">
                <div class="ps-title">Price Summary</div>

                <div class="ps-row">
                    <span>Flight 1</span>
                    <span id="summaryFlight1">@Model.OutboundFlight.Price$</span>
                </div>

                <div class="ps-row" id="summaryFlight2Row" style="display:none;">
                    <span>Flight 2</span>
                    <span id="summaryFlight2">0$</span>
                </div>

                <div class="ps-divider"></div>

                <div class="ps-row">
                    <span>Tax (17%)</span>
                    <span id="summaryTax">@((Model.OutboundFlight.Price * 0.17).ToString("F2"))$</span>
                </div>

                <div class="ps-row ps-discount-row">
                    <span>Discount Code</span>
                    <input type="text" class="discount-input" placeholder="Enter code" disabled />
                </div>

                <div class="ps-divider"></div>

                <div class="ps-row ps-total">
                    <span>Total</span>
                    <span id="summaryTotal">@((Model.OutboundFlight.Price * 1.17).ToString("F2"))$</span>
                </div>

                <!-- Purchase Form -->
                <form method="post" asp-controller="User" asp-action="Purchase">
                    <input type="hidden" name="OutboundFlightId" value="@Model.OutboundFlightId" />
                    <input type="hidden" name="ReturnFlightId" id="returnFlightIdInput" value="" />
                    <button type="submit" class="confirm-btn">Confirm Purchase</button>
                </form>

                <a href="/User/Browse" class="back-link">← Back to flights</a>
            </div>
        </div>
    </div>
</div>

@if (TempData["PurchaseError"] != null)
{
    <div class="purchase-error-msg">@TempData["PurchaseError"]</div>
}

<script>
    const returnFlightsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AvailableReturnFlights ?? new List<Flight>()));
    const cityDictJs = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(cityDict));
    const outboundPrice = @Model.OutboundFlight.Price;

    function onReturnFlightChanged() {
        const select = document.getElementById('returnFlightSelect');
        if (!select) return;
        const selectedId = select.value;
        const retCard = document.getElementById('returnFlightCard');
        const retInput = document.getElementById('returnFlightIdInput');

        retInput.value = selectedId;

        if (!selectedId) {
            if (retCard) retCard.style.display = 'none';
            updatePriceSummary(null);
            return;
        }

        const flight = returnFlightsData.find(f => f.Flight_Id === selectedId);
        if (!flight) return;

        document.getElementById('retRoute').textContent =
            (cityDictJs[flight.Departure_Id] || '?') + ' ✈ ' + (cityDictJs[flight.Arrival_Id] || '?');
        document.getElementById('retAirline').textContent = flight.Airline || '—';
        document.getElementById('retFlightNumber').textContent = flight.Flight_Number || '—';
        document.getElementById('retDepDate').textContent = flight.Departure_Date || '—';
        document.getElementById('retDepTime').textContent = flight.Departure_Time || '—';
        document.getElementById('retArrDate').textContent = flight.Arrival_Date || '—';
        document.getElementById('retArrTime').textContent = flight.Arrival_Time || '—';
        document.getElementById('retDuration').textContent = flight.DurationDisplay || '—';
        document.getElementById('retPrice').textContent = flight.Price + '$';
        document.getElementById('retSeats').textContent = flight.Seats_Available;

        if (retCard) retCard.style.display = 'block';
        updatePriceSummary(flight);
    }

    function updatePriceSummary(returnFlight) {
        const retPrice = returnFlight ? returnFlight.Price : 0;
        const subtotal = outboundPrice + retPrice;
        const tax = subtotal * 0.17;
        const total = subtotal + tax;

        document.getElementById('summaryFlight1').textContent = outboundPrice.toFixed(2) + '$';

        const flight2Row = document.getElementById('summaryFlight2Row');
        if (returnFlight) {
            flight2Row.style.display = 'flex';
            document.getElementById('summaryFlight2').textContent = retPrice.toFixed(2) + '$';
        } else {
            flight2Row.style.display = 'none';
        }

        document.getElementById('summaryTax').textContent = tax.toFixed(2) + '$';
        document.getElementById('summaryTotal').textContent = total.toFixed(2) + '$';
    }
</script>