@using SkyPath_Models.Models
@using SkyPath_Models.ViewModel
@model CheckoutViewModel

@{
    ViewData["Title"] = "Checkout";
    Layout = "~/Views/Shared/MasterPage_User.cshtml";

    var cityDict = (Dictionary<string, string>)(ViewBag.CityDict ?? new Dictionary<string, string>());

    string CityName(string id) =>
        (!string.IsNullOrEmpty(id) && cityDict.ContainsKey(id)) ? cityDict[id] : "Unknown";
}

<link rel="stylesheet" href="~/css/CheckoutCSS.css" />

<div class="checkout-container">
    <h2 class="checkout-title">Booking Summary</h2>

    @if (TempData["PurchaseError"] != null)
    {
        <div class="purchase-error-msg">@TempData["PurchaseError"]</div>
    }

    <div class="checkout-layout">

        <!-- LEFT: Flight details -->
        <div class="checkout-left">
            <div class="section-label">Your Flight</div>
            <div class="flight-detail-card">
                <div class="fdc-route">
                    @CityName(Model.OutboundFlight.Departure_Id)
                    <span class="fdc-arrow">✈</span>
                    @CityName(Model.OutboundFlight.Arrival_Id)
                </div>
                <div class="fdc-grid">
                    <div class="fdc-box">
                        <div class="fdc-label">Flight Number</div>
                        <div class="fdc-value">@Model.OutboundFlight.Flight_Number</div>
                    </div>
                    <div class="fdc-box">
                        <div class="fdc-label">Airline</div>
                        <div class="fdc-value">@Model.OutboundFlight.Airline</div>
                    </div>
                    <div class="fdc-box">
                        <div class="fdc-label">Departure</div>
                        <div class="fdc-value">@Model.OutboundFlight.Departure_Date &bull; @Model.OutboundFlight.Departure_Time</div>
                    </div>
                    <div class="fdc-box">
                        <div class="fdc-label">Arrival</div>
                        <div class="fdc-value">@Model.OutboundFlight.Arrival_Date &bull; @Model.OutboundFlight.Arrival_Time</div>
                    </div>
                    <div class="fdc-box">
                        <div class="fdc-label">Duration</div>
                        <div class="fdc-value">@(Model.OutboundFlight.DurationDisplay ?? "—")</div>
                    </div>
                    <div class="fdc-box">
                        <div class="fdc-label">Price</div>
                        <div class="fdc-value fdc-price">@Model.OutboundFlight.Price$</div>
                    </div>
                    <div class="fdc-box">
                        <div class="fdc-label">Seats Left</div>
                        <div class="fdc-value">@Model.OutboundFlight.Seats_Available</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- RIGHT: Price summary -->
        <div class="checkout-right">
            <div class="price-summary">
                <div class="ps-title">Price Summary</div>

                <div class="ps-row">
                    <span>Flight</span>
                    <span id="summaryFlight">@Model.OutboundFlight.Price$</span>
                </div>

                <div class="ps-row ps-discount-row">
                    <span>Discount Code</span>
                    <div class="discount-field">
                        <input type="text" id="discountCodeInput" class="discount-input" placeholder="Enter code" />
                        <button type="button" class="apply-discount-btn" onclick="applyDiscount()">Apply</button>
                    </div>
                    <span id="discountMsg" class="discount-msg"></span>
                </div>

                <div class="ps-row" id="discountRow" style="display:none;">
                    <span id="discountLabel">Discount</span>
                    <span id="summaryDiscount" style="color:#2a7d4f;">-0$</span>
                </div>

                <div class="ps-divider"></div>

                <div class="ps-row ps-total">
                    <span>Total</span>
                    <span id="summaryTotal">@(Model.OutboundFlight.Price.ToString("F2"))$</span>
                </div>

                <form method="post" asp-controller="User" asp-action="Purchase">
                    <input type="hidden" name="OutboundFlightId" value="@Model.OutboundFlightId" />
                    <input type="hidden" name="DiscountCode" id="discountCodeHidden" value="" />
                    <button type="submit" class="confirm-btn">Confirm Purchase</button>
                </form>

                <a href="/User/Browse" class="back-link">← Back to flights</a>
            </div>
        </div>

    </div>
</div>

<script>
    const flightPrice = @Model.OutboundFlight.Price;
    let appliedDiscountPct = 0;

    function updateSummary() {
        const discountAmt = flightPrice * (appliedDiscountPct / 100);
        const total = flightPrice - discountAmt;

        document.getElementById('summaryFlight').textContent = flightPrice.toFixed(2) + '$';
        document.getElementById('summaryTotal').textContent = total.toFixed(2) + '$';

        const discountRow = document.getElementById('discountRow');
        if (appliedDiscountPct > 0) {
            discountRow.style.display = 'flex';
            document.getElementById('summaryDiscount').textContent = '-' + discountAmt.toFixed(2) + '$';
        } else {
            discountRow.style.display = 'none';
        }
    }

    async function applyDiscount() {
        const code = document.getElementById('discountCodeInput').value.trim();
        const msg = document.getElementById('discountMsg');

        if (!code) {
            msg.textContent = 'Please enter a code.';
            msg.className = 'discount-msg error';
            return;
        }

        msg.textContent = 'Checking...';
        msg.className = 'discount-msg';

        try {
            const res = await fetch('/User/ValidateDiscount?code=' + encodeURIComponent(code));
            const data = await res.json();

            if (data.valid) {
                appliedDiscountPct = data.percentage;
                document.getElementById('discountLabel').textContent = 'Discount (' + data.percentage + '%)';
                document.getElementById('discountCodeHidden').value = code;
                msg.textContent = 'Code applied!';
                msg.className = 'discount-msg success';
            } else {
                appliedDiscountPct = 0;
                document.getElementById('discountCodeHidden').value = '';
                msg.textContent = 'Invalid or expired code.';
                msg.className = 'discount-msg error';
            }
        } catch {
            msg.textContent = 'Could not validate code.';
            msg.className = 'discount-msg error';
        }

        updateSummary();
    }
</script>