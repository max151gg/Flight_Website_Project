@using SkyPath_Models.Models
@using SkyPath_Models.ViewModel
@model CheckoutViewModel

@{
    ViewData["Title"] = "Checkout";
    Layout = "~/Views/Shared/MasterPage_User.cshtml";

    var cityDict = (Dictionary<string, string>)(ViewBag.CityDict ?? new Dictionary<string, string>());
    string CityName(string id) =>
        (!string.IsNullOrEmpty(id) && cityDict.ContainsKey(id)) ? cityDict[id] : "Unknown";

    string currency = (string)(ViewBag.Currency ?? "USD");
    double rate = ViewBag.Rate != null ? (double)ViewBag.Rate : 1.0;
    string selectedDiscountId = (string)(ViewBag.SelectedDiscountId ?? "");

    string[] currencies = { "USD", "EUR", "GBP", "ILS", "JPY", "CAD", "AUD", "CHF", "CNY", "INR" };

    var selectedDiscount = Model.Discounts?.FirstOrDefault(d => d.Discount_Id == selectedDiscountId);
    double pct = selectedDiscount?.Percentage ?? 0;

    double basePrice = Model.OutboundFlight.Price * rate;
    double discountAmt = basePrice * (pct / 100.0);
    double total = basePrice - discountAmt;

    string Money(double v) => v.ToString("F2") + " " + currency;
}

<link rel="stylesheet" href="~/css/CheckoutCSS.css" />

<div class="checkout-container">
    <h2 class="checkout-title">Booking Summary</h2>

    @if (TempData["PurchaseError"] != null)
    {
        <div class="purchase-error-msg">@TempData["PurchaseError"]</div>
    }

    <div class="checkout-layout">

        <!-- LEFT: Flight details -->
        <div class="checkout-left">
            <div class="section-label">Your Flight</div>
            <div class="flight-detail-card">
                <div class="fdc-route">
                    @CityName(Model.OutboundFlight.Departure_Id)
                    <span class="fdc-arrow">✈</span>
                    @CityName(Model.OutboundFlight.Arrival_Id)
                </div>
                <div class="fdc-grid">
                    <div class="fdc-box"><div class="fdc-label">Flight Number</div><div class="fdc-value">@Model.OutboundFlight.Flight_Number</div></div>
                    <div class="fdc-box"><div class="fdc-label">Airline</div><div class="fdc-value">@Model.OutboundFlight.Airline</div></div>
                    <div class="fdc-box"><div class="fdc-label">Departure</div><div class="fdc-value">@Model.OutboundFlight.Departure_Date &bull; @Model.OutboundFlight.Departure_Time</div></div>
                    <div class="fdc-box"><div class="fdc-label">Arrival</div><div class="fdc-value">@Model.OutboundFlight.Arrival_Date &bull; @Model.OutboundFlight.Arrival_Time</div></div>
                    <div class="fdc-box"><div class="fdc-label">Duration</div><div class="fdc-value">@(Model.OutboundFlight.DurationDisplay ?? "—")</div></div>
                    <div class="fdc-box"><div class="fdc-label">Seats Left</div><div class="fdc-value">@Model.OutboundFlight.Seats_Available</div></div>
                </div>
            </div>
        </div>

        <!-- RIGHT: Price summary -->
        <div class="checkout-right">
            <div class="price-summary">
                <div class="ps-title">Price Summary</div>

                <!-- Currency + discount: reloads page on change, recalculated server-side -->
                <form method="get" asp-controller="User" asp-action="Checkout">
                    <input type="hidden" name="flight_id" value="@Model.OutboundFlightId" />

                    <div class="ps-field">
                        <label for="currencySelect">Currency</label>
                        <select id="currencySelect" name="currency" class="ps-select" onchange="this.form.submit()">
                            @foreach (var c in currencies)
                            {
                                var isSelected = c == currency ? "selected" : null;
                                <option value="@c" selected="@(isSelected)">@c</option>
                            }
                        </select>
                    </div>

                    <div class="ps-field">
                        <label for="discountSelect">Discount</label>
                        <select id="discountSelect" name="discountId" class="ps-select" onchange="this.form.submit()">
                            <option value="">No discount</option>
                            @if (Model.Discounts != null)
                            {
                                foreach (var d in Model.Discounts)
                                {
                                    var isSelected = d.Discount_Id == selectedDiscountId ? "selected" : null;
                                    <option value="@d.Discount_Id" selected="@(isSelected)">@(d.Percentage)% OFF - @d.Description</option>
                                }
                            }
                        </select>
                    </div>
                </form>

                <div class="ps-row">
                    <span>Flight</span>
                    <span>@Money(basePrice)</span>
                </div>

                @if (pct > 0)
                {
                    <div class="ps-row">
                        <span>Discount (@pct%)</span>
                        <span style="color:#2a7d4f;">-@Money(discountAmt)</span>
                    </div>
                }

                <div class="ps-divider"></div>

                <div class="ps-row ps-total">
                    <span>Total</span>
                    <span>@Money(total)</span>
                </div>

                <!-- Actual purchase. (Charge is in USD; the currency above is display only.) -->
                <form method="post" asp-controller="User" asp-action="Purchase">
                    <input type="hidden" name="OutboundFlightId" value="@Model.OutboundFlightId" />
                    <input type="hidden" name="DiscountId" value="@selectedDiscountId" />
                    <button type="submit" class="confirm-btn">Confirm Purchase</button>
                </form>

                <a href="/User/Browse" class="back-link">← Back to flights</a>
            </div>
        </div>

    </div>
</div>