<UserControl x:Class="AdminApp.UserControls.CitiesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F5F5">

    <UserControl.Resources>
        <Style x:Key="AddCityButtonStyle" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#667EEA" Offset="0"/>
                        <GradientStop Color="#764BA2" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="22,11"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="➕ " FontSize="16" Margin="0,0,8,0"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                Padding="30,25"
                BorderThickness="0,0,0,1"
                BorderBrush="#E0E0E0">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Cities Management"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#333333"/>
                    <TextBlock Text="Review all cities and add a new city"
                               FontSize="14"
                               Foreground="#999999"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBox Width="250"
                             Height="38"
                             Padding="12,8"
                             FontSize="13"
                             BorderBrush="#E0E0E0"
                             BorderThickness="1"
                             Background="White"
                             x:Name="txtSearch"
                             TextChanged="TxtSearch_TextChanged">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    <TextBlock Text="🔍"
                               FontSize="16"
                               Margin="-35,0,15,0"
                               VerticalAlignment="Center"
                               Foreground="#999999"
                               IsHitTestVisible="False"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Visible"
                      Padding="30,20">
            <ItemsControl x:Name="CitiesList" ItemsSource="{Binding}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White"
                                CornerRadius="12"
                                Margin="0,0,0,15"
                                Padding="20">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000"
                                                  Direction="270"
                                                  ShadowDepth="2"
                                                  BlurRadius="10"
                                                  Opacity="0.08"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="54"
                                        Height="54"
                                        CornerRadius="27"
                                        Background="#667EEA"
                                        Margin="0,0,18,0">
                                    <TextBlock Text="🏙️"
                                               FontSize="26"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding CityName}"
                                                   FontSize="22"
                                                   FontWeight="Bold"
                                                   Foreground="#333333"/>
                                        <Border Background="#333333"
                                                CornerRadius="4"
                                                Padding="8,4"
                                                Margin="12,2,0,0">
                                            <TextBlock Text="{Binding CityId, StringFormat=ID: {0}}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="White"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="Available for route planning"
                                               FontSize="13"
                                               Foreground="#666666"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="White"
                Padding="30,20"
                BorderThickness="0,1,0,0"
                BorderBrush="#E0E0E0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBox x:Name="txtNewCity"
                         Width="320"
                         Height="42"
                         FontSize="14"
                         Padding="12,8"
                         Margin="0,0,12,0"
                         BorderBrush="#DADADA"
                         BorderThickness="1"
                         VerticalContentAlignment="Center"
                         ToolTip="Enter new city name"/>
                <Button Content="Add New City"
                        Style="{StaticResource AddCityButtonStyle}"
                        Click="AddCity_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>