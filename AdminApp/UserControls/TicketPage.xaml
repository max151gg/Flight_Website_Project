<UserControl x:Class="AdminApp.UserControls.TicketPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:AdminApp.Converters"
             Background="#F5F5F5">

    <UserControl.Resources>
        <conv:UserIdToFullNameConverter x:Key="userNameConverter"/>
        <conv:FlightIdToNumberConverter x:Key="flightNumberConverter"/>
        <conv:TicketFlightRouteConverter x:Key="ticketRouteConverter"/>
        <Style x:Key="FilterButtonStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Padding="20,10" Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#667EEA" Offset="0"/>
                                            <GradientStop Color="#764BA2" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#667EEA"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Border" Property="Background" Value="#F8F9FA"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="MinWidth" Value="105"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <Border Background="White" Padding="30,25" BorderThickness="0,0,0,1" BorderBrush="#E0E0E0">
                <StackPanel>
                    <TextBlock Text="Tickets Management" FontSize="28" FontWeight="Bold" Foreground="#333333"/>
                    <TextBlock Text="View and manage all flight ticket bookings" FontSize="14" Foreground="#999999" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Grid Margin="30,20,30,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="2" BlurRadius="10" Opacity="0.08"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="🎫" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Total Tickets" FontSize="13" Foreground="#999999" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock x:Name="txtTotalTickets" Text="0" FontSize="32" FontWeight="Bold" Foreground="#333333" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="2" BlurRadius="10" Opacity="0.08"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="✅" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Active Tickets" FontSize="13" Foreground="#999999" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock x:Name="txtActiveTickets" Text="0" FontSize="32" FontWeight="Bold" Foreground="#28A745" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Background="White" CornerRadius="12" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="2" BlurRadius="10" Opacity="0.08"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="❌" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Cancelled" FontSize="13" Foreground="#999999" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock x:Name="txtCancelledTickets" Text="0" FontSize="32" FontWeight="Bold" Foreground="#DC3545" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="White" Margin="30,15,30,0" CornerRadius="12" Padding="20">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="2" BlurRadius="10" Opacity="0.08"/>
                </Border.Effect>
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Filter Tickets:" FontSize="14" FontWeight="SemiBold" Foreground="#666666" VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <StackPanel Orientation="Horizontal" x:Name="FilterButtons">
                            <RadioButton Content="Show All" Style="{StaticResource FilterButtonStyle}" x:Name="rbAll" IsChecked="True" Checked="FilterChanged" GroupName="TicketFilter"/>
                            <RadioButton Content="Show Active" Style="{StaticResource FilterButtonStyle}" x:Name="rbActive" Checked="FilterChanged" GroupName="TicketFilter" BorderThickness="0,1,1,1"/>
                            <RadioButton Content="Show Cancelled" Style="{StaticResource FilterButtonStyle}" x:Name="rbCancelled" Checked="FilterChanged" GroupName="TicketFilter" BorderThickness="0,1,1,1"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="🔍" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Width="290" Height="38" Padding="12,8" FontSize="13" BorderBrush="#E0E0E0" BorderThickness="1" Background="White" x:Name="txtSearch" TextChanged="TxtSearch_TextChanged" VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Margin="30,20,30,30">
                <ItemsControl x:Name="TicketsList" ItemsSource="{Binding}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="12" Margin="0,0,0,15" Padding="20">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="2" BlurRadius="10" Opacity="0.08"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Margin="0,0,0,15">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🎫" FontSize="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                <TextBlock Text="{Binding Ticket_Id, StringFormat=Ticket {0}}" FontSize="20" FontWeight="Bold" Foreground="#333333" VerticalAlignment="Center"/>
                                                <Border CornerRadius="4" Padding="8,4" Margin="15,0,0,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#28A745"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="False">
                                                                    <Setter Property="Background" Value="#DC3545"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="11" FontWeight="Bold" Foreground="White">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="✅ ACTIVE"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="False">
                                                                        <Setter Property="Text" Value="❌ CANCELLED"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>

                                            <TextBlock Text="{Binding Purchase_Date, StringFormat=Purchased: {0}}" FontSize="13" Foreground="#999999" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>

                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="USER" FontSize="11" Foreground="#999999" Margin="0,0,0,5"/>
                                                <TextBlock Text="{Binding User_Id, Converter={StaticResource userNameConverter}}" FontSize="14" FontWeight="SemiBold" Foreground="#333333"/>
                                                <TextBlock Text="{Binding User_Id}" FontSize="12" Foreground="#999999" Margin="0,3,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="FLIGHT" FontSize="11" Foreground="#999999" Margin="0,0,0,5"/>
                                                <TextBlock Text="{Binding Flight_Id, Converter={StaticResource flightNumberConverter}}" FontSize="14" FontWeight="SemiBold" Foreground="#333333"/>
                                                <TextBlock Text="{Binding Flight_Id}" FontSize="12" Foreground="#999999" Margin="0,3,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="ROUTE" FontSize="11" Foreground="#999999" Margin="0,0,0,5"/>
                                                <TextBlock Text="{Binding Flight_Id, Converter={StaticResource ticketRouteConverter}}" FontSize="14" FontWeight="SemiBold" Foreground="#667EEA"/>
                                            </StackPanel>

                                            
                                        </Grid>
                                    </Grid>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                                        <Button Foreground="White" Click="ToggleTicketStatus_Click" Tag="{Binding}">
                                            <Button.Content>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Cancel Ticket"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="False">
                                                                    <Setter Property="Text" Value="Reactivate"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Button.Content>
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                                    <Setter Property="Background" Value="#FFC107"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="False">
                                                            <Setter Property="Background" Value="#28A745"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <Button Content="Delete Ticket" Style="{StaticResource ActionButtonStyle}" Background="#DC3545" Foreground="White" Margin="5,10,5,0" Click="DeleteTicket_Click" Tag="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>