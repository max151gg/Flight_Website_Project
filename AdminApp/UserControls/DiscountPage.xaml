<UserControl x:Class="AdminApp.UserControls.DiscountPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F5F5">

    <UserControl.Resources>
        <Style x:Key="ModernInputStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="5,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#999999"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#667EEA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Height" Value="42"/>
        </Style>

        <Style x:Key="InputLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="CreateButtonStyle" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#667EEA" Offset="0"/>
                        <GradientStop Color="#764BA2" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DeleteButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#DC3545"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C82333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#667EEA"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ClearFilterButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F8F9FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="30,25" BorderThickness="0,0,0,1" BorderBrush="#E0E0E0">
            <StackPanel>
                <TextBlock Text="Discounts Management" FontSize="28" FontWeight="Bold" Foreground="#333333"/>
                <TextBlock Text="Create and manage promotional discounts" FontSize="14" Foreground="#999999" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,0,20">
            <StackPanel>
                <Border Background="White" Margin="30,20,30,0" CornerRadius="12" Padding="30">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="2" BlurRadius="10" Opacity="0.08"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Create New Discount" FontSize="18" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,20"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="170"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="DESCRIPTION" Style="{StaticResource InputLabelStyle}"/>
                                <TextBox x:Name="txtDescription" Style="{StaticResource ModernInputStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="PERCENTAGE" Style="{StaticResource InputLabelStyle}"/>
                                <TextBox x:Name="txtPercentage" Style="{StaticResource ModernInputStyle}" Text="0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="VALID FROM" Style="{StaticResource InputLabelStyle}"/>
                                <DatePicker x:Name="dpValidFrom" Style="{StaticResource ModernDatePickerStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="6">
                                <TextBlock Text="VALID TO" Style="{StaticResource InputLabelStyle}"/>
                                <DatePicker x:Name="dpValidTo" Style="{StaticResource ModernDatePickerStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="8">
                                <TextBlock Text="USER ID" Style="{StaticResource InputLabelStyle}"/>
                                <TextBox x:Name="txtUserId" Style="{StaticResource ModernInputStyle}"/>
                            </StackPanel>
                        </Grid>
                        <Button Content="Create Discount" Style="{StaticResource CreateButtonStyle}" HorizontalAlignment="Right" Margin="0,20,0,0" Click="CreateDiscount_Click"/>
                    </StackPanel>
                </Border>

                <Border Background="White" Margin="30,15,30,0" CornerRadius="12" Padding="25">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="2" BlurRadius="10" Opacity="0.08"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="250"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Filter by User ID:" FontSize="14" FontWeight="SemiBold" Foreground="#666666" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="2" x:Name="txtFilterUserId" Style="{StaticResource ModernInputStyle}"/>
                        <Button Grid.Column="4" Content="Apply Filter" Style="{StaticResource FilterButtonStyle}" Click="ApplyFilter_Click"/>
                        <Button Grid.Column="6" Content="Clear Filter" Style="{StaticResource ClearFilterButtonStyle}" Click="ClearFilter_Click"/>
                        <TextBlock Grid.Column="7" x:Name="txtFilterStatus" FontSize="13" Foreground="#667EEA" FontStyle="Italic" VerticalAlignment="Center" Margin="20,0,0,0"/>
                    </Grid>
                </Border>

                <Border Background="White" Margin="30,15,30,0" CornerRadius="12" Padding="20" Visibility="Collapsed" x:Name="EmptyState">
                    <TextBlock Text="No discounts found for the current filter." Foreground="#666666" FontSize="14" HorizontalAlignment="Center"/>
                </Border>

                <ItemsControl x:Name="DiscountsList" Margin="30,15,30,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="12" Margin="0,0,0,15" Padding="25">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="2" BlurRadius="10" Opacity="0.08"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Margin="0,0,0,15">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="💰" FontSize="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                <TextBlock Text="{Binding Description}" FontSize="18" FontWeight="Bold" Foreground="#333333" VerticalAlignment="Center"/>
                                                <Border Background="#667EEA" CornerRadius="4" Padding="8,4" Margin="15,0,0,0">
                                                    <TextBlock Text="{Binding PercentageDisplay}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                                <Border Background="#333333"
                                                    CornerRadius="4"
                                                    Padding="8,4"
                                                    Margin="10,5,0,0">
                                                    <TextBlock Text="{Binding DiscountIdDisplay, StringFormat=ID: {0}}"
                                                        FontSize="11"
                                                        FontWeight="SemiBold"
                                                        Foreground="White"/>
                                                </Border>
                                            </StackPanel>
                                            
                                        </Grid>

                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="VALID FROM" FontSize="11" Foreground="#999999" Margin="0,0,0,5"/>
                                                <TextBlock Text="{Binding ValidFromDisplay}" FontSize="14" FontWeight="SemiBold" Foreground="#333333"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="VALID TO" FontSize="11" Foreground="#999999" Margin="0,0,0,5"/>
                                                <TextBlock Text="{Binding ValidToDisplay}" FontSize="14" FontWeight="SemiBold" Foreground="#333333"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="USER ID" FontSize="11" Foreground="#999999" Margin="0,0,0,5"/>
                                                <TextBlock Text="{Binding UserDisplay}" FontSize="14" FontWeight="SemiBold" Foreground="#667EEA"/>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>

                                    <Button Grid.Column="1" Content="Delete" Style="{StaticResource DeleteButtonStyle}" VerticalAlignment="Center" Margin="20,0,0,0" Tag="{Binding SourceDiscount}" Click="DeleteDiscount_Click"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>