<UserControl x:Class="AdminApp.UserControls.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">

    <UserControl.Resources>
        <Style x:Key="DashboardCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="BorderBrush" Value="#E4E4E4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Welcome to the SkyPath Admin App"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#2B2B2B"/>

                <TextBlock Text="Manage flights, users, tickets, discounts, cities, and announcements from one clean control center."
                           FontSize="15"
                           Foreground="#666666"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Hero image -->
        <Border Grid.Row="2"
                CornerRadius="16"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                ClipToBounds="True"
                Background="White"
                MinHeight="210"
                MaxHeight="280">

            <Grid>
                <Image Source="\Images\people-in-the-airport-set-characters-with-a-suitcase-checking-in-on-a-flight-vector.jpg"
                       Stretch="UniformToFill"/>

            </Grid>
        </Border>

        <!-- Bottom cards -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource DashboardCardStyle}">
                <StackPanel>
                    <TextBlock Text="Flights"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#333333"/>

                    <TextBlock Text="Maintain flight schedules, routes, prices, and available seats."
                               FontSize="14"
                               Foreground="#666666"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource DashboardCardStyle}">
                <StackPanel>
                    <TextBlock Text="Users And Tickets"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#333333"/>

                    <TextBlock Text="Manage customer accounts, profiles, orders, and booked tickets."
                               FontSize="14"
                               Foreground="#666666"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource DashboardCardStyle}">
                <StackPanel>
                    <TextBlock Text="Promotions"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#333333"/>

                    <TextBlock Text="Control discounts, public announcements, and city data."
                               FontSize="14"
                               Foreground="#666666"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>