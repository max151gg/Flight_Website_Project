<UserControl x:Class="AdminApp.UserControls.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F5F5">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,25,30,30">
            <TextBlock Text="Welcome to the SkyPath Admin App"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="#333333"
                       Margin="0,0,0,12"/>

            <TextBlock Text="Use this dashboard to manage flights, users, tickets, discounts, and announcements from one place."
                       FontSize="16"
                       Foreground="#666666"
                       TextWrapping="Wrap"
                       Margin="0,0,0,20"/>

            <Border Width="1200"
                    Height="400"
                    MaxWidth="1200"
                    HorizontalAlignment="Left"
                    CornerRadius="12"
                    BorderBrush="#DDDDDD"
                    BorderThickness="1"
                    ClipToBounds="True"
                    Background="White">
                <Image Source="/Images/people-in-the-airport-set-characters-with-a-suitcase-checking-in-on-a-flight-vector.jpg"
                       Width="1200"
                       Height="400"
                       Stretch="UniformToFill"/>
            </Border>

            <Border Margin="0,20,0,0"
                    Padding="18"
                    CornerRadius="10"
                    Background="#FFFFFF"
                    BorderBrush="#E4E4E4"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="What you can do here"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#333333"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="• Maintain and update flight schedules"
                               FontSize="14"
                               Foreground="#555555"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="• Manage customer accounts and profiles"
                               FontSize="14"
                               Foreground="#555555"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="• Track tickets, promotions, and public announcements"
                               FontSize="14"
                               Foreground="#555555"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>